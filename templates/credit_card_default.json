{
  "id": "credit_card_default",
  "name": "Default Credit Card Statement",
  "document_type": "credit_card_statement",
  "enabled": true,
  "detection": {
    "document_identifiers": {
      "card_number_patterns": [
        "\\*{4}\\s*\\*{4}\\s*\\*{4}\\s*[0-9]{4}",
        "Card\\s*(?:Number|No\\.?):\\s*\\*+\\s*[0-9]{4}",
        "[0-9]{4}\\s*[0-9]{4}\\s*[0-9]{4}\\s*[0-9]{4}",
        "[0-9]{4}\\s*[0-9]{2}\\*{2}\\s*\\*{4}\\s*[0-9]{4}",
        "[0-9]{4}\\s+[0-9X*]{2}\\*{2}\\s+\\*{4}\\s+[0-9]{4}"
      ],
      "account_reference_patterns": [
        "Account\\s*(?:Number|No\\.?):\\s*[A-Z0-9-]+",
        "Card\\s*Account:\\s*[A-Z0-9-]+"
      ]
    },
    "header_keywords": [
      "Credit Card Statement",
      "Card Statement",
      "Credit Card Account"
    ],
    "filename_patterns": [
      "*credit*card*.pdf",
      "*card*statement*.pdf",
      "*visa*.pdf",
      "*mastercard*.pdf"
    ],
    "column_headers": [
      "Date",
      "Transaction",
      "Amount"
    ]
  },
  "extraction": {
    "table_top_y": 300,
    "table_bottom_y": 720,
    "enable_header_check": true,
    "header_check_top_y": 250,
    "columns": {
      "Transaction Date": [26, 100],
      "Posting Date": [100, 174],
      "Description": [174, 400],
      "Amount": [400, 480]
    }
  },
  "processing": {
    "supports_multiline": true,
    "date_format": "%d/%m/%Y",
    "currency_symbol": "€",
    "decimal_separator": ".",
    "transaction_types": {
      "purchase": ["PURCHASE", "SALE", "POS"],
      "payment": ["PAYMENT", "DIRECT DEBIT"],
      "fee": ["FEE", "CHARGE", "INTEREST"],
      "refund": ["REFUND", "REVERSAL", "CREDIT"]
    }
  },
  "metadata": {
    "description": "Generic template for credit card statements",
    "supported_issuers": ["Visa", "Mastercard", "American Express"],
    "notes": "Detects card numbers in masked format (e.g., **** **** **** 1234)"
  }
}
