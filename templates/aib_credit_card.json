{
  "id": "aib_credit_card",
  "name": "AIB Credit Card Statement",
  "document_type": "credit_card_statement",
  "enabled": true,
  "detection": {
    "document_identifiers": {
      "card_number_patterns": [
        "\\*{4}\\s*\\*{4}\\s*\\*{4}\\s*[0-9]{4}",
        "[0-9]{4}\\s*[0-9]{2}\\*{2}\\s*\\*{4}\\s*[0-9]{4}",
        "[0-9]{4}\\s+[0-9X*]{2}\\*{2}\\s+\\*{4}\\s+[0-9]{4}"
      ]
    },
    "header_keywords": [
      "Credit Card Statement",
      "AIB Credit Card"
    ],
    "exclude_keywords": [
      "IBAN",
      "Personal Bank Account",
      "Statement of Account"
    ],
    "filename_patterns": [
      "*aib*credit*card*.pdf",
      "*aib*card*.pdf"
    ],
    "column_headers": [
      "Date",
      "Transaction Details",
      "Debit",
      "Credit"
    ]
  },
  "extraction": {
    "table_top_y": 320,
    "table_bottom_y": 720,
    "enable_header_check": true,
    "header_check_top_y": 250,
    "columns": {
      "Date": [29, 78],
      "Transaction Details": [78, 320],
      "Debit €": [320, 400],
      "Credit €": [400, 480]
    }
  },
  "processing": {
    "supports_multiline": true,
    "date_format": "%d %b %Y",
    "currency_symbol": "€",
    "decimal_separator": ".",
    "transaction_types": {
      "purchase": ["POS", "CONTACTLESS", "ONLINE"],
      "payment": ["PAYMENT RECEIVED", "DIRECT DEBIT"],
      "fee": ["ANNUAL FEE", "LATE FEE", "FOREIGN TRANSACTION"],
      "refund": ["REFUND", "CREDIT"]
    }
  },
  "metadata": {
    "description": "AIB-specific credit card statement template",
    "issuer": "Allied Irish Banks",
    "card_types": ["Visa", "Mastercard"],
    "notes": "Uses same date format as AIB bank statements (dd MMM yyyy)"
  }
}
