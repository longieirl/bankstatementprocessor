#!/bin/bash

# Pre-push hook to prevent direct pushes to protected branches
# This provides additional protection for private repositories with limited GitHub features

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Protected branches
PROTECTED_BRANCHES="main develop master"

# Get current branch
current_branch=$(git symbolic-ref HEAD | sed -e 's,.*/\(.*\),\1,')

# Check if current branch is protected
for branch in $PROTECTED_BRANCHES; do
    if [ "$current_branch" = "$branch" ]; then
        echo -e "${RED}❌ BLOCKED: Direct pushes to '$branch' are not allowed!${NC}"
        echo -e "${YELLOW}📋 Proper workflow:${NC}"
        echo -e "  1. Create a feature branch: ${GREEN}git checkout -b feature/your-feature${NC}"
        echo -e "  2. Make your changes and commit them"
        echo -e "  3. Push the feature branch: ${GREEN}git push origin feature/your-feature${NC}"
        echo -e "  4. Create a Pull Request on GitHub"
        echo -e "  5. Get approval and merge through GitHub UI"
        echo ""
        echo -e "${YELLOW}🔧 To push to current branch anyway (emergency):${NC}"
        echo -e "  ${GREEN}git push --no-verify origin $branch${NC}"
        exit 1
    fi
done

# Read stdin for push details
while read local_ref local_sha remote_ref remote_sha; do
    # Extract branch name from remote ref
    remote_branch=$(echo "$remote_ref" | sed -e 's,.*/\(.*\),\1,')

    # Check if pushing to protected branch
    for branch in $PROTECTED_BRANCHES; do
        if [ "$remote_branch" = "$branch" ]; then
            echo -e "${RED}❌ BLOCKED: Pushing to '$branch' is not allowed!${NC}"
            echo -e "${YELLOW}📋 Use Pull Requests to update protected branches.${NC}"
            exit 1
        fi
    done
done

echo -e "${GREEN}✅ Push allowed to '$current_branch'${NC}"
exit 0